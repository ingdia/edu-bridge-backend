// prisma/schema.prisma
// EDU-Bridge Database Schema - Aligned with SRS v1.0
// Prisma Version: 5.22.0 | Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS (SRS 2.3: User Classes & FR 3-4: Learning Types)
// ─────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

enum ExerciseType {
  LISTENING
  SPEAKING
  READING
  WRITING
  DIGITAL_LITERACY
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  INTERVIEW
  ACCEPTED
  REJECTED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  SESSION_REMINDER
  DEADLINE_ALERT
  FEEDBACK_RECEIVED
  APPLICATION_UPDATE
  SYSTEM_ANNOUNCEMENT
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum OpportunityType {
  JOB
  INTERNSHIP
  SCHOLARSHIP
  UNIVERSITY
  TRAINING
}

// ─────────────────────────────────────────────────────────────
// CORE AUTH (SRS FR 1: Authentication & NFR 1: Security)
// ─────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String // Hashed with bcrypt (NFR 1)
  role      Role      @default(STUDENT)
  isActive  Boolean   @default(true)
  lastLogin DateTime?

  // Email verification
  emailVerified     Boolean   @default(false)
  verificationToken String?   @unique
  verificationTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentProfile StudentProfile?
  mentorProfile  MentorProfile?
  adminProfile   AdminProfile?
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([role, isActive])
}

// ─────────────────────────────────────────────────────────────
// STUDENT PROFILE (SRS FR 2: Profile Management)
// ─────────────────────────────────────────────────────────────

model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal Data
  fullName    String
  dateOfBirth DateTime
  nationalId  String   @unique
  schoolName  String   @default("GS Ruyenzi")
  gradeLevel  String

  // Parent/Guardian
  guardianName    String?
  guardianContact String?
  relationship    String?

  // Socio-Economic (Sensitive - NFR 10)
  familyIncome     String?
  occupation       String?
  livingConditions String?

  // Location
  homeAddress String?
  district    String?
  province    String?

  // Confidential Notes
  mentorNotes String? @db.Text

  // Profile Photo
  profilePhotoUrl String?

  // Primary Mentor Assignment (SRS FR 7)
  assignedMentorId String?
  assignedMentor   MentorProfile? @relation(fields: [assignedMentorId], references: [id], name: "AssignedMentor", onDelete: SetNull)

  // Relations
  progress        Progress[]
  academicReports AcademicReport[]
  mentorSessions  MentorshipSession[] @relation(name: "StudentSessions")
  cv              CV?                 @relation(name: "StudentCV")
  applications    JobApplication[]
  exerciseSubmissions ExerciseSubmission[]
  notifications   Notification[]
  digitalLiteracyProgress DigitalLiteracyProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([nationalId])
  @@index([district, gradeLevel])
  @@index([assignedMentorId])
}

// ─────────────────────────────────────────────────────────────
// MENTOR PROFILE (SRS FR 7: Mentorship)
// ─────────────────────────────────────────────────────────────

model MentorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expertise String[]
  bio       String?  @db.Text

  // Profile Photo
  profilePhotoUrl String?

  // Primary Assigned Students
  assignedStudents StudentProfile[] @relation(name: "AssignedMentor")

  // Session-Based Interactions
  sessions MentorshipSession[]
  
  // Exercise Evaluations
  exerciseEvaluations ExerciseSubmission[]
  
  // Notifications sent by mentor
  sentNotifications Notification[] @relation(name: "MentorNotifications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// ADMIN PROFILE
// ─────────────────────────────────────────────────────────────

model AdminProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  permissions String[]

  // Profile Photo
  profilePhotoUrl String?
  
  // Relations
  sentNotifications Notification[] @relation(name: "AdminNotifications")
  managedOpportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// LEARNING MODULES & PROGRESS (SRS FR 3-4)
// ─────────────────────────────────────────────────────────────

model LearningModule {
  id                String       @id @default(uuid())
  title             String
  description       String?      @db.Text
  type              ExerciseType
  contentUrl        String
  difficulty        String
  estimatedDuration Int?

  progress Progress[]
  exerciseSubmissions ExerciseSubmission[]

  isActive   Boolean @default(true)
  orderIndex Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, difficulty])
  @@index([isActive, orderIndex])
}

model Progress {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  moduleId String
  module   LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  score       Int?
  feedback    String?   @db.Text
  completedAt DateTime?
  timeSpent   Int?

  // Offline Sync Support (SRS 2.4)
  isSynced     Boolean   @default(true)
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, moduleId])
  @@index([studentId, completedAt])
  @@index([moduleId, score])
}


// ─────────────────────────────────────────────────────────────
// EXERCISE SUBMISSIONS (SRS FR 3: Exercise Types)
// ─────────────────────────────────────────────────────────────

model ExerciseSubmission {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  moduleId String
  module   LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  exerciseType ExerciseType
  
  // Flexible JSON for type-specific responses:
  // • LISTENING/READING: { responses: [{ questionId, answer }] }
  // • WRITING: { content, wordCount }
  // • SPEAKING: { audioUrl, transcript, recordingDuration }
  // • DIGITAL_LITERACY: { completed, artifactUrl, notes }
  submissionContent Json

  // Evaluation fields (nullable until mentor reviews)
  score        Int?
  feedback     String?      @db.Text
  rubricScores Json?        // e.g., { "grammar": 8, "clarity": 9 }
  isPassed     Boolean?
  evaluatedAt  DateTime?
  evaluatedBy  String?
  evaluator    MentorProfile? @relation(fields: [evaluatedBy], references: [id], onDelete: SetNull)

  status       String       @default("pending") // "pending" | "evaluated"
  submittedAt  DateTime     @default(now())

  // Offline sync support (matches Progress pattern)
  isSynced     Boolean      @default(true)
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, submittedAt])
  @@index([moduleId, exerciseType])
  @@index([status, evaluatedAt])
  @@index([studentId, status]) // For mentor dashboard filtering
}

// ─────────────────────────────────────────────────────────────
// ACADEMIC REPORTS (SRS FR 5)
// ─────────────────────────────────────────────────────────────

model AcademicReport {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  term     String
  year     Int
  fileUrl  String
  fileName String?
  fileSize Int?

  subjects     Json?
  overallGrade String?
  remarks      String? @db.Text

  enteredBy  String
  verifiedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, year, term])
  @@index([enteredBy])
}

// ─────────────────────────────────────────────────────────────
// MENTORSHIP SESSIONS (SRS FR 7)
// ─────────────────────────────────────────────────────────────

model MentorshipSession {
  id String @id @default(uuid())

  mentorId String
  mentor   MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade, name: "StudentSessions")

  scheduledFor DateTime
  duration     Int      @default(60)
  location     String?

  notes       String?       @db.Text
  actionItems String?       @db.Text
  status      SessionStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, scheduledFor])
  @@index([mentorId, status])
}

// ─────────────────────────────────────────────────────────────
// MESSAGING SYSTEM (SRS FR 7.1)
// ─────────────────────────────────────────────────────────────

model Message {
  id String @id @default(uuid())

  // Sender (can be student or mentor)
  senderUserId String
  senderRole   Role

  // Recipient (can be student or mentor)
  recipientUserId String
  recipientRole   Role

  // Message content
  subject String?
  content String @db.Text

  // Attachments (optional - for future file sharing)
  attachments Json?

  // Message status
  isRead    Boolean   @default(false)
  readAt    DateTime?
  isDeleted Boolean   @default(false)

  // Thread support (optional - for grouping conversations)
  threadId String?
  replyTo  String? // ID of message being replied to

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderUserId, createdAt])
  @@index([recipientUserId, isRead])
  @@index([threadId])
  @@index([senderUserId, recipientUserId])
}

// ─────────────────────────────────────────────────────────────
// INCREMENT 2: CAREER GUIDANCE (SRS FR 8)
// ─────────────────────────────────────────────────────────────

model CV {
  id        String         @id @default(uuid())
  studentId String         @unique
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade, name: "StudentCV")

  content            Json
  template           String? @default("standard")
  isSharedWithMentor Boolean @default(true)

  // ← OPPOSITE RELATION FOR JobApplication.cv (FIX)
  jobApplications JobApplication[] @relation(name: "CVApplications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

model JobApplication {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  position       String
  organization   String
  type           String
  deadline       DateTime?
  applicationUrl String?

  status      ApplicationStatus @default(DRAFT)
  submittedAt DateTime?
  response    String?           @db.Text

  // Supporting Docs - FIXED RELATION
  cvId        String?
  cv          CV?     @relation(fields: [cvId], references: [id], name: "CVApplications", onDelete: SetNull)
  coverLetter String? @db.Text

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, status])
  @@index([type, deadline])
}

// ─────────────────────────────────────────────────────────────
// SYSTEM: AUDIT & SECURITY (SRS NFR 1, 5, 10)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action     String
  entityType String?
  entityId   String?

  ipAddress String?
  userAgent String?

  details Json?

  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@index([action, timestamp])
}

model RefreshToken {
  id     String @id @default(uuid())
  token  String @unique
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId, revoked])
}

model PasswordResetToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, used])
}

// ─────────────────────────────────────────────────────────────
// DIGITAL LITERACY MODULES (SRS FR 4)
// ─────────────────────────────────────────────────────────────

model DigitalLiteracyProgress {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  lessonTitle String
  lessonType  String // "email", "computer_basics", "internet_safety", "digital_communication"
  
  completed   Boolean   @default(false)
  score       Int?
  completedAt DateTime?
  
  practiceData Json? // Stores practice exercises, simulations, etc.
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, lessonType])
  @@index([completed])
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS SYSTEM (SRS FR 9)
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  
  recipientId String
  recipient   StudentProfile @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  
  type    NotificationType
  status  NotificationStatus @default(UNREAD)
  
  title   String
  message String @db.Text
  
  // Optional links
  actionUrl String?
  metadata  Json? // Additional context (session ID, application ID, etc.)
  
  // Sender tracking (optional)
  sentByMentorId String?
  sentByMentor   MentorProfile? @relation(fields: [sentByMentorId], references: [id], name: "MentorNotifications", onDelete: SetNull)
  
  sentByAdminId String?
  sentByAdmin   AdminProfile? @relation(fields: [sentByAdminId], references: [id], name: "AdminNotifications", onDelete: SetNull)
  
  // Email notification tracking
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?
  
  readAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientId, status])
  @@index([type, createdAt])
  @@index([status, createdAt])
}

// ─────────────────────────────────────────────────────────────
// OPPORTUNITY MATCHING (SRS FR 8.3)
// ─────────────────────────────────────────────────────────────

model Opportunity {
  id String @id @default(uuid())
  
  title        String
  organization String
  type         OpportunityType
  description  String @db.Text
  
  // Requirements
  minGrade        String? // e.g., "60%", "B+"
  requiredSkills  String[] // e.g., ["English", "Computer Literacy"]
  gradeLevel      String[] // e.g., ["S4", "S5", "S6"]
  location        String?
  
  // Application details
  applicationUrl String?
  deadline       DateTime?
  contactEmail   String?
  
  // Metadata
  isActive    Boolean @default(true)
  postedBy    String?
  postedByAdmin AdminProfile? @relation(fields: [postedBy], references: [id], onDelete: SetNull)
  
  viewCount   Int @default(0)
  applyCount  Int @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive])
  @@index([deadline, isActive])
  @@index([gradeLevel])
}
